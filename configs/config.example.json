{
  "api_key": "${CLAUDEPASS_API_KEY}",
  "host": "127.0.0.1",
  "port": 3456,
  "hot_reload": false,
  "enable_streaming_scenario_routing": false,
  "respect_requested_model": false,

  "models": {
    "background": {
      "provider": "openai",
      "model_id": "gpt-4o-mini",
      "temperature": 0.5,
      "max_tokens": 2048
    },
    "default": {
      "provider": "openai",
      "model_id": "gpt-4o",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "long_context": {
      "provider": "openai",
      "model_id": "gpt-4o",
      "temperature": 0.7,
      "max_tokens": 16384,
      "context_threshold": 80000
    },
    "think": {
      "provider": "openai",
      "model_id": "o3",
      "temperature": 0.7,
      "max_tokens": 8192,
      "reasoning_effort": "max",
      "thinking": {
        "type": "enabled"
      }
    },
    "complex": {
      "provider": "openai",
      "model_id": "o3",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "fast": {
      "provider": "openai",
      "model_id": "gpt-4o-mini",
      "temperature": 0.7,
      "max_tokens": 4096
    }
  },

  "fallbacks": {
    "default": [
      { "provider": "openai", "model_id": "gpt-4o-mini" }
    ],
    "think": [
      { "provider": "openai", "model_id": "gpt-4o" }
    ]
  },

  "upstream": {
    "base_url": "https://api.openai.com/v1/chat/completions",
    "timeout_ms": 300000
  },

  "logging": {
    "level": "info",
    "requests": true
  }
}
